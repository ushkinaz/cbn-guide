{
  "name": "cbn-guide",
  "version": "1.7.0",
  "private": true,
  "repository": {
    "url": "https://github.com/ushkinaz/cbn-guide"
  },
  "homepage": "https://cataclysmbn-guide.com/",
  "author": {
    "name": "nornagon",
    "url": "https://github.com/nornagon"
  },
  "maintainers": [
    {
      "name": "ushkinaz",
      "url": "https://github.com/ushkinaz"
    }
  ],
  "contributors": [
    {
      "name": "MythosMod",
      "url": "https://github.com/mythosmod"
    }
  ],
  "type": "module",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "pnpm lint:format",
    "lint:format": "prettier -c .",
    "lint:fix": "prettier -w .",
    "check": "pnpm check:types",
    "check:types": "svelte-check && tsc --noEmit",
    "test": "pnpm lint && pnpm check && pnpm gen:mod-tests && pnpm test:full",
    "test:full": "vitest run src",
    "test:fast": "vitest run src --exclude \"src/all.*.test.ts\" --exclude \"src/__mod_tests__/**\"",
    "test:render:core": "vitest run \"src/all.*.test.ts\"",
    "test:render:mods": "vitest run src/__mod_tests__",
    "test:changed": "pnpm lint && pnpm check && vitest run --changed --run",
    "fetch:fixtures": "tsx scripts/fetch-fixtures.ts",
    "fetch:fixtures:nightly": "tsx scripts/fetch-fixtures.ts nightly",
    "fetch:builds": "tsx scripts/fetch-builds.ts",
    "fetch:icons": "tsx scripts/fetch-icons.ts",
    "gen:mod-tests": "tsx scripts/gen-mod-tests.ts",
    "gen:css": "tsx scripts/gen-css.ts",
    "gen:sitemap": "tsx scripts/gen-sitemap.ts",
    "gen:ogimage": "python3 scripts/gen-ogimage.py",
    "gen:unifont": "python3 scripts/gen-unifont.py",
    "bench:node": "tsx scripts/bench-node.ts",
    "bench:browser": "tsx scripts/bench-browser.ts",
    "bench:browser:batch": "tsx scripts/bench-browser-batch.ts",
    "bench:report": "tsx scripts/bench-report.ts",
    "i18n:push": "txjs-cli push dist",
    "i18n:download": "tsx scripts/transifex-download.ts",
    "i18n:upload": "tsx scripts/transifex-upload.ts",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/traverse": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/svelte": "^5.3.1",
    "@transifex/cli": "^7.1.5",
    "@tsconfig/svelte": "^5.0.8",
    "@types/gettext.js": "^2.0.0",
    "@types/node": "^24.10.15",
    "@types/requestidlecallback": "^0.3.7",
    "@vite-pwa/assets-generator": "^1.0.2",
    "ajv": "^8.18.0",
    "esbuild": "^0.27.3",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "puppeteer": "^24.40.0",
    "sharp": "^0.33.5",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "ts-json-schema-generator": "^2.9.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "undici": "^7.24.4",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "workbox-build": "^7.4.0"
  },
  "dependencies": {
    "@sentry/browser": "^10.45.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@transifex/native": "^7.1.5",
    "fuzzysort": "^3.1.0",
    "gettext.js": "^2.0.3",
    "workbox-window": "^7.4.0",
    "zaraz-ts": "^1.2.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "overrides": {}
  }
}
